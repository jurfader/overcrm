APP_NAME=OVERCRM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=overcrm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# === Brand (override w Settings → Branding po setupie) ===
BRAND_NAME=OVERCRM
BRAND_SHORT_NAME=OVERCRM
BRAND_PRIMARY=#3B82F6
BRAND_SECONDARY=#1F2937
BRAND_LOGO_URL=/logo.svg
BRAND_LOGO_DARK_URL=/logo-dark.svg
BRAND_SUPPORT_EMAIL=
BRAND_SUPPORT_PHONE=

# === Licensing (OVERMEDIA license server) ===
OVERCRM_LICENSE_KEY=
LICENSE_SERVER_URL=http://51.38.137.199:3002
OVERCRM_INSTALL_ID=
APP_DOMAIN=

# === AI providers ===
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# === Polish Pack (opcjonalne, włączane w Settings) ===
FAKTUROWNIA_API_KEY=
FAKTUROWNIA_DOMAIN=
APILO_CLIENT_ID=
APILO_CLIENT_SECRET=
APILO_INSTANCE_URL=
GUS_API_KEY=

# === Telephony / VoIP (opcjonalne) ===
RINGOSTAT_AUTH_KEY=
RINGOSTAT_PROJECT_ID=
PLAY_CLIENT_ID=
PLAY_CLIENT_SECRET=
PLAY_PRIVATE_KEY=

# === Mail provider (opcjonalne) ===
MAILERSEND_API_KEY=

# === InPost (opcjonalne) ===
INPOST_GEOWIDGET_TOKEN=
INPOST_ORGANIZATION_ID=

# === AWS S3 (opcjonalne) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Ukryta rola developerska — pełne uprawnienia admina (oddzielone przecinkami)
# DEVELOPER_EMAILS=dev@example.com,other@example.com
